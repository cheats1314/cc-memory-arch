{
  "name": "cc-memory-arch",
  "version": "1.0.5",
  "license": "MIT",
  "description": "Memory routing & curation discipline for Claude Code",
  "author": {
    "name": "cheats1314",
    "email": "dengjiang0331@gmail.com"
  },
  "homepage": "https://github.com/cheats1314/cc-memory-arch",
  "repository": "https://github.com/cheats1314/cc-memory-arch",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-mem-write.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-mem-write.sh" }
        ]
      }
    ]
  }
}
